}
.playlist-container.dark-mode .add-to-item.data-v-0755d4e3 {
  border-bottom: 0.5px solid #374151;
}
.playlist-container.dark-mode .add-to-item.data-v-0755d4e3:active {
  background-color: #374151;
}
