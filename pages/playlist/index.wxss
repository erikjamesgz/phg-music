.song-menu-modal.data-v-0755d4e3 {
  width: 100%;
  max-height: 70vh;
  background-color: #fff;
  border-radius: 16px 16px 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.song-menu-header.data-v-0755d4e3 {
  padding: 16px;
  border-bottom: 0.5px solid #f0f0f0;
  text-align: center;
}
.song-menu-title.data-v-0755d4e3 {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  margin-bottom: 4px;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.song-menu-artist.data-v-0755d4e3 {
  font-size: 13px;
  color: #999;
  display: block;
}
.song-menu-actions.data-v-0755d4e3 {
  display: flex;
  justify-content: space-around;
  padding: 20px 16px;
  border-bottom: 0.5px solid #f0f0f0;
}
.menu-action-item.data-v-0755d4e3 {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10px;
}
.menu-action-icon.data-v-0755d4e3 {
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: #f5f5f5;
  margin-bottom: 8px;
}
.menu-action-icon.is-favorite.data-v-0755d4e3 {
  background-color: rgba(239, 68, 68, 0.1);
}
.menu-action-text.data-v-0755d4e3 {
  font-size: 13px;
  color: #333;
}

/* 子菜单 */
.song-menu-submenu.data-v-0755d4e3 {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #fff;
  display: flex;
  flex-direction: column;
}
.submenu-header.data-v-0755d4e3 {
  display: flex;
  align-items: center;
  padding: 12px 16px;
  border-bottom: 0.5px solid #f0f0f0;
}
.submenu-back.data-v-0755d4e3 {
  display: flex;
  align-items: center;
  color: #666;
  font-size: 14px;
  margin-right: 10px;
}
.submenu-title.data-v-0755d4e3 {
  flex: 1;
  font-size: 15px;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-right: 40px;
}
.submenu-content.data-v-0755d4e3 {
  flex: 1;
  max-height: 50vh;
}
.add-to-item.data-v-0755d4e3 {
  display: flex;
  align-items: center;
  padding: 12px 16px;
  border-bottom: 0.5px solid #f8f8f8;
}
.add-to-item.data-v-0755d4e3:active {
  background-color: #f9fafb;
}
.add-to-icon.data-v-0755d4e3 {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  background-color: #f5f5f5;
  margin-right: 12px;
}
.add-to-info.data-v-0755d4e3 {
  flex: 1;
}
.add-to-name.data-v-0755d4e3 {
  font-size: 15px;
  color: #333;
  margin-bottom: 2px;
  display: block;
}
.add-to-count.data-v-0755d4e3 {
  font-size: 12px;
  color: #999;
}

/* 暗黑模式适配 */
.playlist-container.dark-mode .song-menu-modal.data-v-0755d4e3 {
  background-color: #1f2937;
}
.playlist-container.dark-mode .song-menu-header.data-v-0755d4e3 {
  border-bottom: 0.5px solid #374151;
}
.playlist-container.dark-mode .song-menu-title.data-v-0755d4e3 {
  color: #f0f0f0;
}
.playlist-container.dark-mode .song-menu-artist.data-v-0755d4e3 {
  color: #9ca3af;
}
.playlist-container.dark-mode .song-menu-actions.data-v-0755d4e3 {
  border-bottom: 0.5px solid #374151;
}
.playlist-container.dark-mode .menu-action-icon.data-v-0755d4e3 {
  background-color: #374151;
}
.playlist-container.dark-mode .menu-action-text.data-v-0755d4e3 {
  color: #f0f0f0;
}
.playlist-container.dark-mode .song-menu-submenu.data-v-0755d4e3 {
  background-color: #1f2937;
}
.playlist-container.dark-mode .submenu-header.data-v-0755d4e3 {
  border-bottom: 0.5px solid #374151;
}
.playlist-container.dark-mode .submenu-back.data-v-0755d4e3 {
