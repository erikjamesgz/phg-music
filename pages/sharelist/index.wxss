/* 文章场景相关 */
.playlist-page.data-v-cab5a59c {
  display: flex;
  flex-direction: column;
  height: 100vh;
  position: relative;
  background-color: #f8f9fa;
}

/* 固定头部区域 */
.header-fixed.data-v-cab5a59c {
  flex-shrink: 0;
  position: relative;
  z-index: 10;
  background: transparent;
}

/* 背景图 */
.background-wrapper.data-v-cab5a59c {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 55vh;
  z-index: 0;
  overflow: hidden;
}
.background-image.data-v-cab5a59c {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: blur(15px) brightness(0.7);
  transform: scale(1.2);
}
.background-image.gradient-background.data-v-cab5a59c {
  filter: brightness(0.7);
}
.background-overlay.data-v-cab5a59c {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to bottom, rgba(0, 0, 0, 0.3) 0%, rgba(0, 0, 0, 0.5) 50%, #f8f9fa 100%);
}

/* 状态栏占位 - 完全透明，让背景图透过来 */
.status-bar-placeholder.data-v-cab5a59c {
  flex-shrink: 0;
  width: 100%;
  position: relative;
  z-index: 10;
  background: transparent !important;
}

/* 歌单头部 - 固定不滚动，包含安全高度 */
.playlist-header.data-v-cab5a59c {
  padding: 0 15px 15px;
  position: relative;
  z-index: 10;
  flex-shrink: 0;
  width: 100%;
  box-sizing: border-box;
  background: transparent;
}

/* 头部操作区 */
.header-actions.data-v-cab5a59c {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15px;
}
.back-btn.data-v-cab5a59c {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: transparent;
  color: #fff;
}
.back-btn roc-icon-plus.data-v-cab5a59c {
  color: #fff !important;
}
.page-title.data-v-cab5a59c {
  font-size: 16px;
  font-weight: 600;
  color: #fff;
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
}
.placeholder.data-v-cab5a59c {
  width: 32px;
}

/* 歌单信息 - 确保flex布局不影响子元素尺寸 */
.playlist-info.data-v-cab5a59c {
  display: flex;
  align-items: flex-start;
  width: 100%;
  box-sizing: border-box;
}

/* 歌单封面 - 使用背景图方式，最可靠的尺寸控制 */
.playlist-cover-bg.data-v-cab5a59c {
  width: 120px;
  height: 120px;
  min-width: 120px;
  max-width: 120px;
  flex-shrink: 0;
  flex-grow: 0;
  flex-basis: 120px;
  border-radius: 8px;
  overflow: hidden;
  position: relative;
  margin-right: 15px;
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
  border: 1px solid rgba(255, 255, 255, 0.1);
  box-sizing: border-box;
  background-size: cover !important;
  background-position: center !important;
  background-repeat: no-repeat !important;
}
.playlist-cover-bg.gradient-cover.data-v-cab5a59c {
  display: flex;
  align-items: center;
  justify-content: center;
}
.gradient-content.data-v-cab5a59c {
  display: flex;
  align-items: center;
  justify-content: center;
}
.gradient-background.data-v-cab5a59c {
  display: flex;
  align-items: center;
  justify-content: center;
}
.play-count-tag.data-v-cab5a59c {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.7), transparent);
  padding: 4px 6px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.play-count-tag > view.data-v-cab5a59c {
  margin-right: 2px;
}
.play-count-tag > view.data-v-cab5a59c:last-child {
