  align-items: center;
}
.play-count-tag text.data-v-cab5a59c {
  color: #fff;
  font-size: 10px;
  white-space: nowrap;
  line-height: 1;
}
.playlist-details.data-v-cab5a59c {
  flex: 1;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  min-width: 0;
}
.playlist-title.data-v-cab5a59c {
  font-size: 17px;
  font-weight: bold;
  color: #fff;
  margin-bottom: 6px;
  line-height: 1.3;
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
}
.creator-info.data-v-cab5a59c {
  display: flex;
  align-items: center;
  margin-bottom: 5px;
}
.creator-name.data-v-cab5a59c {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.9);
}
.playlist-desc-wrapper.data-v-cab5a59c {
  max-height: 50px;
