}

/* 操作按钮栏 - 集成到歌单信息区域 */
.action-bar.data-v-cab5a59c {
  display: flex;
  align-items: center;
  flex-direction: row;
  margin-top: auto;
}
.action-btn.data-v-cab5a59c {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 6px 10px;
  border-radius: 15px;
  gap: 3px;
  white-space: nowrap;
  flex-shrink: 0;
}
.action-btn + .action-btn.data-v-cab5a59c {
  margin-left: 8px;
}
.action-btn text.data-v-cab5a59c {
  font-size: 12px;
  font-weight: 500;
}

/* 小屏幕适配 */
@media (max-width: 400px) {
.action-btn.data-v-cab5a59c {
    flex: 1;
    min-width: 0;
    padding: 5px 8px;
}
.action-btn + .action-btn.data-v-cab5a59c {
    margin-left: 6px;
}
.action-btn text.data-v-cab5a59c {
    font-size: 11px;
}
}
.action-btn.data-v-cab5a59c roc-icon-plus {
  flex-shrink: 0;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}
.collect-btn.data-v-cab5a59c {
