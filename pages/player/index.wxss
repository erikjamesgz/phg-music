/* 文章场景相关 */
.player-page {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  background-color: #ffffff;
}

/* 暗黑模式下的页面背景 */
.player-page.dark-mode {
  background-color: #1f2937;
}
.status-bar-placeholder {
  flex-shrink: 0;
  width: 100%;
}
.player-navbar {
  height: 120rpx;
  padding-top: var(--status-bar-height, 44rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  padding-left: 30rpx;
  padding-right: 30rpx;
  position: relative;
  /* 平板适配 - 缩小导航栏 */
  /* 中等屏幕手机适配（如 iPhone XR, iPhone 11） */
  /* 小屏幕手机适配（如 iPhone 5, iPhone SE） */
  /* 矮屏设备适配（如折叠屏内屏） */
}
.player-navbar__left {
  position: absolute;
  left: 30rpx;
  top: var(--status-bar-height, 44rpx);
  transform: translateY(-50%);
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  z-index: 10;
}
.player-navbar__right {
  position: absolute;
  right: 30rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  z-index: 10;
}
.player-navbar__center {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  max-width: 60%;
  position: absolute;
  left: 50%;
  top: var(--status-bar-height, 44rpx);
  transform: translate(-50%, -50%);
}
.player-navbar__subtitle {
  font-size: 28rpx;
  color: #374151;
  font-weight: 500;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.player-navbar__source {
  font-size: 22rpx;
  color: #6b7280;
  margin-top: 4rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}
@media screen and (min-width: 768px) {
.player-navbar {
    height: 66rpx;
}
.player-navbar__left {
    width: 50rpx;
    height: 50rpx;
    top: calc(var(--status-bar-height, 44rpx) + 10rpx);
}
.player-navbar__subtitle {
    font-size: 18rpx;
}
.player-navbar__source {
    font-size: 14rpx;
}
.player-navbar__center {
    top: calc(var(--status-bar-height, 44rpx) + 0rpx);
    transform: translateX(-50%);
}
}
@media screen and (max-height: 896px) and (min-height: 813px) {
.player-navbar {
    height: 80rpx;
}
.player-navbar__left {
    width: 72rpx;
    height: 72rpx;
}
.player-navbar__subtitle {
    font-size: 26rpx;
}
.player-navbar__source {
    font-size: 20rpx;
}
}
@media screen and (max-height: 812px) {
.player-navbar {
    height: 70rpx;
}
.player-navbar__left {
    width: 64rpx;
    height: 64rpx;
}
.player-navbar__subtitle {
    font-size: 24rpx;
}
.player-navbar__source {
    font-size: 18rpx;
}
}
@media screen and (max-height: 800px) and (min-width: 700px) {
.player-navbar {
    height: 60rpx;
}
.player-navbar__left {
    width: 56rpx;
    height: 56rpx;
}
.player-navbar__subtitle {
    font-size: 24rpx;
}
.player-navbar__source {
    font-size: 18rpx;
}
}

/* 暗黑模式下的导航栏文字 */
.player-page.dark-mode .player-navbar__subtitle {
  color: #f3f4f6;
}
.player-page.dark-mode .player-navbar__source {
  color: #9ca3af;
}
.player-page.dark-mode .player-navbar__left {
  background: rgba(255, 255, 255, 0.1);
}

/* 导航栏跑马灯样式 */
.player-navbar__marquee {
  overflow: hidden;
  position: relative;
  min-width: 0;
  height: 36rpx;
  display: flex;
  align-items: center;
  max-width: 100%;
}
.player-navbar__marquee-content {
  display: flex;
  align-items: center;
  white-space: nowrap;
  flex-shrink: 0;
}
.player-navbar__marquee-content.scroll {
  animation: marquee 10s linear infinite;
}
.player-navbar__separator {
  flex-shrink: 0;
}

/* 歌曲信息状态栏样式 */
.song-info__status {
  margin-top: 8rpx;
  overflow: hidden;
  width: 100%;
  text-align: center;
  display: flex;
  justify-content: center;
}
.song-info__status-marquee {
  overflow: hidden;
  position: relative;
  min-width: 0;
  height: 32rpx;
  display: flex;
  align-items: center;
  max-width: 100%;
  width: 100%;
}
.song-info__status-content {
  display: flex;
  align-items: center;
  white-space: nowrap;
  flex-shrink: 0;
  margin: 0 auto;
}
.song-info__status-content.scroll {
  animation: marquee 8s linear infinite;
}
.song-info__status-text {
  font-size: 24rpx;
  color: #00c4b8;
  font-weight: 500;
  flex-shrink: 0;
}
.song-info__status-gap {
  flex-shrink: 0;
}

/* 跑马灯动画 */
@keyframes marquee {
0% {
    transform: translateX(0);
}
100% {
    transform: translateX(-50%);
}
}
.slide-indicator {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
  margin-bottom: 0;
  padding: 0;
  position: absolute;
  left: 50%;
  top: calc(var(--status-bar-height, 44rpx) + 60rpx);
  transform: translateX(-50%);
  /* 平板适配 - 缩小指示器区域 */
  /* 中等屏幕手机适配（如 iPhone XR, iPhone 11） */
  /* 小屏幕手机适配（如 iPhone 5, iPhone SE） */
  /* 矮屏设备适配（如折叠屏内屏） */
}
@media screen and (min-width: 768px) {
.slide-indicator {
    margin-top: 4rpx;
    margin-bottom: 0;
    padding: 0;
    top: calc(var(--status-bar-height, 44rpx) + 55rpx);
}
}
@media screen and (max-height: 896px) and (min-height: 813px) {
.slide-indicator {
    margin-top: 8rpx;
    margin-bottom: 8rpx;
    padding: 4rpx 0;
}
}
@media screen and (max-height: 812px) {
.slide-indicator {
    margin-top: 6rpx;
    margin-bottom: 6rpx;
    padding: 3rpx 0;
}
}
@media screen and (max-height: 800px) and (min-width: 700px) {
.slide-indicator {
    margin-top: 4rpx;
    margin-bottom: 4rpx;
    padding: 2rpx 0;
}
}
.slide-arrow {
  position: absolute;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
  transition: all 0.2s ease;
}
.slide-arrow:active {
  transform: translateY(-50%) scale(0.95);
  background: rgba(255, 255, 255, 0.4);
}
.slide-arrow--left {
  left: 20rpx;
}
.slide-arrow--right {
  right: 20rpx;
}

/* 暗黑模式下的滑动箭头 */
.player-page.dark-mode .slide-arrow {
  background: rgba(255, 255, 255, 0.1);
}
.player-page.dark-mode .slide-arrow:active {
  background: rgba(255, 255, 255, 0.2);
}
.indicator-dot {
  width: 24rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #9ca3af;
  transition: all 0.3s ease;
}
.indicator-dot.active {
  width: 48rpx;
  background: linear-gradient(90deg, #00d7cd 0%, #00afff 100%);
  opacity: 1;
}
.player-swiper {
  flex: 1;
  height: 0;
  position: relative;
}
.album-view {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 40rpx;
  height: 100%;
  box-sizing: border-box;
  position: relative;
}
.album-cover-wrapper {
  position: relative;
  width: 520rpx;
  height: 520rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  flex: 2;
  min-height: 0;
}

/* 平板适配 - 较大屏幕 */
@media screen and (min-width: 768px) {
.album-cover-wrapper {
    width: 420rpx;
    height: 420rpx;
}
}
/* iPad设备适配 - 再缩小20% */
@media screen and (min-width: 768px) and (min-height: 1024px) {
.album-cover-wrapper {
    width: 336rpx;
    height: 336rpx;
}
}
/* 中等屏幕手机适配（如 iPhone XR, iPhone 11）- 从480rpx增大20% */
@media screen and (max-height: 896px) and (min-height: 813px) {
.album-cover-wrapper {
    width: 576rpx;
    height: 576rpx;
}
}
/* 小屏幕手机适配（如 iPhone 5, SE, 6, 7, 8, X）- 从380rpx增大30% */
@media screen and (max-height: 812px) {
.album-cover-wrapper {
    width: 494rpx;
    height: 494rpx;
}
}
/* 矮屏设备适配（如折叠屏内屏 799px，华为Mate X6 781px）- 缩小20% */
@media screen and (max-height: 800px) and (min-width: 700px) {
.album-cover-wrapper {
    width: 272rpx;
    height: 272rpx;
}
}
.turntable-shadow {
  position: absolute;
  width: calc(100% + 40rpx);
  padding-bottom: calc(100% + 40rpx);
  height: 0;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(0, 0, 0, 0.06) 0%, transparent 70%);
  z-index: 0;
}
.turntable {
  position: relative;
  width: 100%;
  height: 100%;
  max-width: 520rpx;
  max-height: 520rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
  animation: turntableRotate 20s linear infinite;
  animation-play-state: paused;
  will-change: transform;
}

/* 平板适配 */
@media screen and (min-width: 768px) {
.turntable {
    max-width: 420rpx;
    max-height: 420rpx;
}
}
/* iPad设备适配 - 再缩小20% */
@media screen and (min-width: 768px) and (min-height: 1024px) {
.turntable {
    max-width: 336rpx;
    max-height: 336rpx;
}
}
/* 中等屏幕手机适配 */
@media screen and (max-height: 896px) and (min-height: 813px) {
.turntable {
    max-width: 576rpx;
    max-height: 576rpx;
}
}
/* 小屏幕手机适配 */
@media screen and (max-height: 812px) {
.turntable {
    max-width: 494rpx;
    max-height: 494rpx;
}
}
/* 矮屏设备适配 */
@media screen and (max-height: 800px) and (min-width: 700px) {
.turntable {
    max-width: 272rpx;
    max-height: 272rpx;
}
}
/* 华为 pura x 内屏适配 - 440*707 */
@media screen and (min-width: 430px) and (max-width: 460px) and (min-height: 700px) and (max-height: 720px) {
.turntable {
    max-width: 395rpx;
    max-height: 395rpx;
}
}
.turntable.is-playing {
  animation-play-state: running;
}
@keyframes turntableRotate {
from {
    transform: rotate(0deg);
}
to {
    transform: rotate(360deg);
}
}
.turntable-metal-ring {
  position: absolute;
  width: 100%;
  padding-bottom: 100%;
  height: 0;
  border-radius: 50%;
  background: linear-gradient(145deg, #e5e7eb 0%, #d1d5db 50%, #e5e7eb 100%);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.08), inset 0 1rpx 2rpx rgba(255, 255, 255, 0.8);
}
.turntable-border {
  position: absolute;
  width: calc(100% - 6rpx);
  padding-bottom: calc(100% - 6rpx);
  height: 0;
  border-radius: 50%;
  background: linear-gradient(135deg, #00d7cd 0%, #00afff 100%);
}
.turntable-groove {
  position: absolute;
  width: calc(100% - 12rpx);
  padding-bottom: calc(100% - 12rpx);
  height: 0;
  border-radius: 50%;
  background: linear-gradient(180deg, #fafafa 0%, #f3f4f6 100%);
  border: 1rpx solid rgba(0, 0, 0, 0.03);
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}
.turntable-cover {
  position: absolute;
  width: calc(100% - 80rpx);
  padding-bottom: calc(100% - 80rpx);
  height: 0;
  border-radius: 50%;
  overflow: hidden;
  background: linear-gradient(135deg, #f9fafb 0%, #f3f4f6 50%, #e5e7eb 100%);
  box-shadow: inset 0 2rpx 6rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}
.turntable-cover.has-image {
  background: transparent;
  box-shadow: none;
}
.turntable-cover__image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}
.turntable-cover__placeholder {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}
.turntable-cover__placeholder .placeholder-icon {
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(0, 215, 205, 0.08) 0%, rgba(0, 175, 255, 0.08) 100%);
  border: 1rpx solid rgba(0, 215, 205, 0.15);
}
.turntable-center {
  position: absolute;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}
.turntable-center__dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #00d7cd 0%, #00afff 100%);
  box-shadow: 0 3rpx 12rpx rgba(0, 215, 205, 0.4), inset 0 1rpx 3rpx rgba(255, 255, 255, 0.6);
  border: 3rpx solid rgba(255, 255, 255, 0.95);
}
.tonearm {
  position: absolute;
  top: 0;
  right: 10%;
  width: 80rpx;
  height: 180rpx;
  z-index: 20;
  transform-origin: 40rpx 25rpx;
  transform: rotate(-20deg);
  transition: transform 2s cubic-bezier(0.25, 0.1, 0.25, 1);
  /* 中等屏幕手机适配（如 iPhone XR, iPhone 11）- 转盘增大，唱针臂也增大 */
  /* 小屏幕手机适配（如 iPhone 5, iPhone SE）- 转盘增大，唱针臂也增大 */
  /* 矮屏设备适配（如折叠屏内屏，华为Mate X6）- 缩小20% */
}
@media screen and (max-height: 896px) and (min-height: 813px) {
.tonearm {
    width: 85rpx;
    height: 190rpx;
    transform-origin: 43rpx 24rpx;
    right: 5%;
}
}
@media screen and (max-height: 812px) {
.tonearm {
    width: 82rpx;
    height: 185rpx;
    transform-origin: 41rpx 25rpx;
    right: 5%;
}
}
@media screen and (max-height: 800px) and (min-width: 700px) {
.tonearm {
    width: 48rpx;
    height: 112rpx;
    transform-origin: 24rpx 16rpx;
    right: 8%;
}
}
.tonearm__pivot {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #f3f4f6 0%, #e5e7eb 100%);
  box-shadow: 0 3rpx 10rpx rgba(0, 0, 0, 0.08), inset 0 1rpx 3rpx rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  /* 中等屏幕手机适配（如 iPhone XR, iPhone 11） */
  /* 小屏幕手机适配（如 iPhone 5, iPhone SE） */
  /* 矮屏设备适配（如折叠屏内屏，华为Mate X6）- 缩小20% */
}
.tonearm__pivot-inner {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #d1d5db 0%, #9ca3af 100%);
  box-shadow: inset 0 1rpx 3rpx rgba(0, 0, 0, 0.1);
}
@media screen and (max-height: 896px) and (min-height: 813px) {
.tonearm__pivot {
    width: 50rpx;
    height: 50rpx;
}
.tonearm__pivot-inner {
    width: 20rpx;
    height: 20rpx;
}
}
@media screen and (max-height: 812px) {
.tonearm__pivot {
    width: 48rpx;
    height: 48rpx;
}
.tonearm__pivot-inner {
    width: 19rpx;
    height: 19rpx;
}
}
@media screen and (max-height: 800px) and (min-width: 700px) {
.tonearm__pivot {
    width: 32rpx;
    height: 32rpx;
}
.tonearm__pivot-inner {
    width: 13rpx;
    height: 13rpx;
}
}
.tonearm__rod {
  position: absolute;
  top: 25rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 6rpx;
  height: 140rpx;
  background: linear-gradient(90deg, #d1d5db 0%, #e5e7eb 40%, #e5e7eb 60%, #d1d5db 100%);
  border-radius: 3rpx;
  /* 中等屏幕手机适配（如 iPhone XR, iPhone 11） */
  /* 小屏幕手机适配（如 iPhone 5, iPhone SE） */
  /* 矮屏设备适配（如折叠屏内屏，华为Mate X6）- 缩小20% */
}
@media screen and (max-height: 896px) and (min-height: 813px) {
.tonearm__rod {
    top: 24rpx;
    width: 6rpx;
    height: 150rpx;
}
}
@media screen and (max-height: 812px) {
.tonearm__rod {
    top: 25rpx;
    width: 6rpx;
    height: 145rpx;
}
}
@media screen and (max-height: 800px) and (min-width: 700px) {
.tonearm__rod {
    top: 16rpx;
    width: 4rpx;
    height: 88rpx;
}
}
.tonearm__cartridge {
  position: absolute;
  bottom: 10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 28rpx;
  height: 40rpx;
  background: linear-gradient(145deg, #6b7280 0%, #4b5563 100%);
  border-radius: 6rpx 6rpx 10rpx 10rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.15);
  /* 中等屏幕手机适配（如 iPhone XR, iPhone 11） */
  /* 小屏幕手机适配（如 iPhone 5, iPhone SE） */
  /* 矮屏设备适配（如折叠屏内屏，华为Mate X6）- 缩小20% */
}
.tonearm__cartridge::after {
  content: "";
  position: absolute;
  bottom: -6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 6rpx;
  height: 12rpx;
  background: #374151;
  border-radius: 0 0 3rpx 3rpx;
}
@media screen and (max-height: 896px) and (min-height: 813px) {
.tonearm__cartridge {
    width: 28rpx;
    height: 40rpx;
}
.tonearm__cartridge::after {
    width: 6rpx;
    height: 11rpx;
}
}
@media screen and (max-height: 812px) {
.tonearm__cartridge {
    width: 26rpx;
    height: 38rpx;
}
.tonearm__cartridge::after {
    width: 5rpx;
    height: 11rpx;
}
}
@media screen and (max-height: 800px) and (min-width: 700px) {
.tonearm__cartridge {
    bottom: 6rpx;
    width: 18rpx;
    height: 26rpx;
}
.tonearm__cartridge::after {
    width: 4rpx;
    height: 8rpx;
}
}
.tonearm-playing {
  transform: rotate(8deg);
}
.song-info-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 100%;
  flex: 1;
  min-height: 0;
}

/* 平板适配 - 转盘420rpx，按比例缩小 */
