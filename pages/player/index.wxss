  border: 2rpx solid rgba(255, 107, 107, 0.3);
}
.source-switch-hint {
  position: absolute;
  top: -28rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e8e 100%);
  color: #ffffff;
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
