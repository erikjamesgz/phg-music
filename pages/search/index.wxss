/* 搜索分类标签 */
.search-types {
  flex-shrink: 0;
  white-space: nowrap;
  margin-top: 16px;
  margin-bottom: 0;
  height: 40px;
  border-bottom: 1px solid #eeeeee;
  background-color: #ffffff;
  /* 微信小程序中使用固定颜色 */
  position: -webkit-sticky;
  position: sticky;
  top: 0;
  z-index: 10;
  padding: 0;
}
.search-types-inner {
  display: flex;
  padding: 0 16px;
  align-items: center;
  column-gap: 24px;
  /* 使用column-gap确保间距一致 */
}
.search-type-item {
  display: inline-block;
  padding: 0 0;
  height: 40px;
  line-height: 40px;
  font-size: 14px;
  font-weight: 500;
  color: #666666;
  position: relative;
  transition: all 0.2s ease;
  padding-bottom: 2px;
  /* 添加底部内边距，与设计稿一致 */
}
.search-type-item:active {
  transform: scale(0.95);
}
.search-type-item.active {
  color: #333333;
  font-weight: bold;
}
.search-type-item.active::after {
  content: "";
  position: absolute;
  bottom: 5px;
  left: 10%;
  width: 80%;
  height: 4px;
  background: linear-gradient(90deg, #00d7cd, #00afff);
  /* 使用与设计稿完全一致的颜色 */
  border-radius: 2.5px;
  animation: fadeIn 0.3s ease-in-out;
}
@keyframes fadeIn {
from {
    opacity: 0;
    transform: scaleX(0.5);
}
to {
    opacity: 1;
    transform: scaleX(1);
}
}
/* 搜索背景 */
.search-container {
  display: flex;
  flex-direction: column;
  height: 100%;
  overflow: hidden;
  background-color: #ffffff;
  /* 微信小程序中使用固定颜色 */
}

/* 状态栏占位 */
.status-bar-placeholder {
  flex-shrink: 0;
  width: 100%;
  background-color: #ffffff;
}

/* 搜索头部 */
.search-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8px 16px;
  background-color: #ffffff;
  /* 微信小程序中使用固定颜色 */
  position: relative;
  z-index: 10;
  flex-shrink: 0;
}
.search-header.ios {
  padding-top: 8px;
  padding-bottom: 12px;
}
.search-input-wrapper {
  display: flex;
  align-items: center;
  flex: 1;
  max-width: 80%;
  height: 40px;
  padding: 0 12px;
  background-color: #f2f2f2;
  /* 微信小程序中使用固定颜色 */
  border-radius: 20px;
  transition: all 0.3s ease;
}
.search-input-wrapper.focused {
  box-shadow: 0 0 0 2px #7fd4d2;
}
.search-input-wrapper.with-cancel {
  max-width: 75%;
}
.search-icon {
  margin-right: 8px;
}
.search-input {
  flex: 1;
  width: 0;
  /* 解决小程序flex布局宽度问题 */
  min-width: 0;
  /* 确保内容溢出时收缩 */
  height: 40px;
  font-size: 14px;
  color: #333333;
  background-color: transparent;
  box-sizing: border-box;
  /* 包含内边距和边框 */
}
.clear-icon {
  padding: 6px;
}
.search-btn {
  font-size: 14px;
  color: #666666;
  margin-left: 12px;
  padding: 6px;
  text-align: center;
}

/* 搜索内容区域 */
.search-content {
  flex: 1;
  width: 100%;
  position: relative;
  z-index: 1;
  overflow: hidden;
  background-color: #ffffff;
  /* 微信小程序中使用固定颜色 */
}

/* 搜索历史 */
.search-section {
  margin-bottom: 20px;
  padding: 0 15px;
  background-color: #ffffff;
  /* 微信小程序中使用固定颜色 */
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 15px 0 10px;
}
.section-header .section-title {
  position: relative;
  padding-left: 10px;
}
.section-header .section-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 4px;
  height: 18px;
  background: linear-gradient(to bottom, #00afff, #00d9c6);
  border-radius: 2px;
}
.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #333333;
}
.clear-history {
  display: flex;
  align-items: center;
  font-size: 12px;
  color: #666666;
}
.clear-history .iconfont {
  font-size: 14px;
  margin-right: 2px;
}
.history-tags {
  display: flex;
  flex-wrap: wrap;
}
.history-tag {
  display: flex;
  align-items: center;
  padding: 6px 12px;
  margin: 0 10px 10px 0;
  background-color: #f5f5f5;
  /* 微信小程序中使用固定颜色 */
  border-radius: 15px;
  font-size: 12px;
  color: #333333;
}
.history-tag-delete {
  font-size: 16px;
  color: #666666;
  margin-left: 5px;
  width: 20px;
  height: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 热搜榜 */
.hot-search-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}
.hot-search-grid-item {
  display: flex;
  align-items: flex-start;
  padding: 8px 0;
  min-width: 0;
  overflow: hidden;
}
.hot-search-rank {
  width: 24px;
  text-align: center;
  font-size: 18px;
  font-weight: bold;
  color: #666666;
  margin-right: 12px;
}
.top-rank-celadon {
  color: #3aa39f;
}
.top-rank-azure {
  color: #4a90e2;
}
.normal-rank {
  color: #666666;
}
.hot-search-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
  overflow: hidden;
}
.refresh-hot {
  font-size: 12px;
  color: #3aa39f;
}
.hot-search-word {
  font-size: 14px;
  color: #333333;
  font-weight: bold;
  margin-bottom: 2px;
}
.hot-search-score {
  font-size: 12px;
  color: #666666;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.hot-search-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 2px;
}
.hot-search-count {
  font-size: 12px;
  color: #999999;
  display: block;
}
.hot-search-source {
  font-size: 10px;
  color: #999999;
  background-color: rgba(0, 0, 0, 0.05);
  border-radius: 4px;
  padding: 1px 4px;
  display: inline-block;
}

/* 搜索建议 */
.suggestion-list {
  display: flex;
  flex-direction: column;
  padding: 0 15px;
  animation: fadeIn 0.3s ease-out;
}
.suggestion-item {
  display: flex;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #eeeeee;
}
.suggestion-item .iconfont {
  font-size: 16px;
  color: #666666;
  margin-right: 10px;
}
.suggestion-text {
  font-size: 14px;
  color: #333333;
}

/* 搜索结果 */
.search-result {
  padding: 15px 15px 0;
  animation: fadeInUp 0.3s ease-out;
  background-color: #ffffff;
}
.dark-mode .search-result {
  background-color: #1f2937;
}
@keyframes fadeInUp {
from {
    opacity: 0;
    transform: translateY(10px);
}
to {
    opacity: 1;
    transform: translateY(0);
}
}
/* 单曲列表 */
.song-list {
  display: flex;
  flex-direction: column;
}
.song-item {
  display: flex;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #f5f5f5;
}
.song-item.playing {
  background: linear-gradient(to right, rgba(0, 215, 205, 0.05), rgba(0, 175, 255, 0.05));
  border-radius: 16rpx;
  border-color: rgba(0, 215, 205, 0.1);
  padding: 24rpx 16rpx;
  margin: 0 -16rpx;
}
.song-info {
  flex: 1;
  overflow: hidden;
}
.song-name {
  font-size: 14px;
  color: #333333;
  margin-bottom: 4px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.song-details {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.song-artist {
  font-size: 12px;
  color: #999999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.song-quality-duration {
  display: flex;
  align-items: center;
  gap: 8px;
}
.song-quality {
  font-size: 10px;
  color: #00d7cd;
  background-color: rgba(0, 215, 205, 0.1);
  padding: 1px 4px;
  border-radius: 2px;
  border: 1px solid rgba(0, 215, 205, 0.3);
}
.song-source {
  font-size: 10px;
  color: #999999;
  background-color: rgba(0, 0, 0, 0.05);
  border-radius: 4px;
  padding: 0 4px;
  margin-right: 8px;
}
.song-duration {
  font-size: 10px;
  color: #999999;
}
.song-actions {
  display: flex;
  align-items: center;
}
.song-actions .iconfont {
  font-size: 24px;
  color: #999999;
  margin-left: 15px;
}
.song-index {
  width: 60rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  margin-right: 20rpx;
}

/* 歌手网格 */
.artist-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -5px;
}
.artist-grid-item {
  width: 33.33%;
  padding: 0 5px;
  margin-bottom: 15px;
}
.artist-grid-avatar {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 50%;
  margin-bottom: 5px;
}
.artist-grid-name {
  font-size: 12px;
  color: #333333;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 专辑列表 */
.album-list {
  display: flex;
  flex-direction: column;
}
.album-list-item {
  display: flex;
  padding: 12px 0;
  border-bottom: 1px solid #eeeeee;
}
.album-list-cover {
  width: 60px;
  height: 60px;
  border-radius: 4px;
  margin-right: 10px;
}
.album-list-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.album-list-name {
  font-size: 14px;
  color: #333333;
  margin-bottom: 4px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.album-list-artist {
  font-size: 12px;
  color: #666666;
  margin-bottom: 4px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.album-list-time {
  font-size: 12px;
  color: #999999;
}
.album-list-source {
  font-size: 11px;
  color: #999999;
  margin-top: 4px;
  padding: 1px 4px;
  background-color: rgba(0, 0, 0, 0.05);
  border-radius: 5px;
  display: inline-block;
}

/* 歌单网格 */
.playlist-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}
.playlist-grid-item {
  width: calc((100% - 12px) / 2);
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  margin-bottom: 0;
  padding: 0;
}
.cover-wrapper {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
}
.source-tag {
  position: absolute;
  top: 6px;
  left: 6px;
  display: flex;
  align-items: center;
  background: rgba(0, 0, 0, 0.5);
  padding: 2px 6px;
  border-radius: 10px;
  font-size: 10px;
  color: #fff;
  line-height: 1;
}
.cover-image {
  width: 100%;
  height: 100%;
}
.play-count {
  position: absolute;
  bottom: 10px;
  right: 50px;
  display: flex;
  align-items: center;
  background: rgba(0, 0, 0, 0.5);
  padding: 2px 6px;
  border-radius: 10px;
}
.play-count roc-icon-plus {
  display: flex;
  align-items: center;
  justify-content: center;
}
.play-count text {
  font-size: 10px;
  color: #fff;
  margin-left: 2px;
  line-height: 1;
}
.song-count {
  position: absolute;
  bottom: 10px;
  right: 6px;
  display: flex;
  align-items: center;
  background: rgba(0, 0, 0, 0.5);
  padding: 2px 6px;
  border-radius: 10px;
}
.song-count roc-icon-plus {
  display: flex;
  align-items: center;
  justify-content: center;
}
.song-count text {
  font-size: 10px;
  color: #fff;
  margin-left: 2px;
  line-height: 1;
}
.songlist-info {
  padding: 10px;
}
.songlist-name {
  font-size: 14px;
  font-weight: 500;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.songlist-meta {
  margin-top: 4px;
  font-size: 12px;
  color: #666;
  display: flex;
  align-items: center;
}
.songlist-author {
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.songlist-separator {
  margin: 0 4px;
  color: #999;
}
.songlist-source {
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.songlist-time {
  font-size: 9px;
  color: #bbb;
}
.search-container.dark-mode .playlist-grid-item {
  background-color: #374151;
  box-shadow: none;
}
.search-container.dark-mode .songlist-name {
  color: #f3f4f6;
}
.search-container.dark-mode .songlist-meta {
  color: #9ca3af;
}
.search-container.dark-mode .songlist-author {
  color: #9ca3af;
}
.search-container.dark-mode .songlist-time {
  color: #6b7280;
}
.search-container.dark-mode .songlist-source {
  color: #9ca3af;
}

