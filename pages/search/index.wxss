/* 加载中 */
.loading {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 100px;
  color: #666666;
  animation: fadeIn 0.3s ease-out;
}

/* 无搜索结果 */
.no-result {
  display: flex;
  flex: 1;
  min-height: 60vh;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.5s ease-out;
}
.no-result-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px;
  text-align: center;
  max-width: 80%;
}
.no-result-image {
  margin-bottom: 32px;
  opacity: 0.8;
}
.no-result-text {
  font-size: 16px;
  color: #333333;
  margin-bottom: 8px;
  font-weight: 500;
}
.no-result-tips {
  font-size: 14px;
  color: #666666;
  margin-top: 8px;
}
.retry-button {
  margin-top: 20px;
  background-color: #3aa39f;
  color: #fff;
  font-size: 14px;
  padding: 6px 20px;
  border-radius: 20px;
  border: none;
}

/* 加载更多 */
.loading-more {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 40px;
  color: #666666;
  font-size: 13px;
  padding: 10px 0;
}
.loading-more:active {
  opacity: 0.7;
}

/* 底部安全区域 */
.safe-bottom {
  height: 0;
}

/* 查看更多按钮 */
.view-more {
  display: flex;
  justify-content: center;
  padding: 12px 0;
  margin-bottom: 20px;
}
.view-more text {
  font-size: 13px;
  color: #3aa39f;
  padding: 6px 12px;
  border: 1px solid #7fd4d2;
  border-radius: 16px;
  background-color: rgba(58, 163, 159, 0.05);
}

/* 搜索建议样式 */
.search-suggestions {
  background-color: #ffffff;
  border-radius: 8px;
  margin: 10px 15px;
  padding: 5px 0;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}
.suggestion-item {
  display: flex;
  align-items: center;
  padding: 12px 15px;
}
.suggestion-icon {
  margin-right: 10px;
}
.suggestion-text {
  font-size: 14px;
  color: #333333;
}

/* 综合搜索中的分区标题 */
.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #333333;
  margin: 15px 0 10px;
  padding-left: 10px;
  position: relative;
}
.section-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 4px;
  height: 16px;
  background: linear-gradient(to bottom, #3aa39f, #4a90e2);
  border-radius: 2px;
}

/* 暗黑模式样式 - 与 playlist 页面保持一致 */
.search-container.dark-mode {
  background-color: #1f2937;
}
.search-container.dark-mode .search-header {
  background-color: #1f2937;
}
.search-container.dark-mode .search-input-wrapper {
  background-color: #374151;
}
.search-container.dark-mode .search-input-wrapper .search-input {
  color: #f0f0f0;
}
.search-container.dark-mode .search-icon,
.search-container.dark-mode .clear-icon {
  color: #9ca3af;
}
.search-container.dark-mode .search-btn {
  color: #f0f0f0;
}
.search-container.dark-mode .search-types {
  background-color: #1f2937 !important;
  border-bottom-color: #374151;
}
.search-container.dark-mode .search-types .search-type-item {
  color: #9ca3af;
}
.search-container.dark-mode .search-types .search-type-item.active {
  color: #00d7cd;
}
.search-container.dark-mode .search-content {
  background-color: #1f2937;
}
.search-container.dark-mode .search-section {
  background-color: #1f2937;
}
.search-container.dark-mode .section-title {
  color: #f0f0f0;
}
.search-container.dark-mode .clear-history {
  color: #9ca3af;
}
.search-container.dark-mode .search-history-title {
  color: #f0f0f0;
}
.search-container.dark-mode .history-tag {
  background-color: #374151 !important;
  color: #f0f0f0;
}
.search-container.dark-mode .history-tag-delete {
  color: #9ca3af;
}
.search-container.dark-mode .hot-search-grid-item {
  background-color: #1f2937;
  border-bottom: 1rpx solid #374151;
}
.search-container.dark-mode .hot-search-word {
  color: #f0f0f0;
}
.search-container.dark-mode .hot-search-score,
.search-container.dark-mode .hot-search-count,
.search-container.dark-mode .hot-search-source {
  color: #9ca3af;
}
.search-container.dark-mode .refresh-hot {
  color: #00d7cd;
}
.search-container.dark-mode .loading {
  color: #f0f0f0;
}
.search-container.dark-mode .loading-spinner {
  border-color: rgba(0, 215, 205, 0.3);
  border-top-color: #00d7cd;
}
.search-container.dark-mode .no-result .no-result-text,
.search-container.dark-mode .no-result .no-result-tips {
  color: #9ca3af;
}
.search-container.dark-mode .no-result .no-result-image {
  color: #6b7280;
}
.search-container.dark-mode .song-list {
  background-color: #1f2937;
}
.search-container.dark-mode .song-item {
  border-bottom: 1rpx solid #374151;
}
.search-container.dark-mode .song-item.playing {
  background: linear-gradient(to right, rgba(0, 215, 205, 0.1), rgba(0, 175, 255, 0.1));
  border-color: rgba(0, 215, 205, 0.2);
}
.search-container.dark-mode .song-index {
  color: #9ca3af;
}
.search-container.dark-mode .song-name {
  color: #f0f0f0;
}
.search-container.dark-mode .song-artist {
  color: #9ca3af;
}
.search-container.dark-mode .song-quality {
  background-color: rgba(0, 215, 205, 0.2);
  color: #33dfd8;
}
.search-container.dark-mode .song-source {
  color: #9ca3af;
  background-color: rgba(255, 255, 255, 0.1);
}
.search-container.dark-mode .song-duration {
  color: #9ca3af;
}
.search-container.dark-mode .song-actions .iconfont {
  color: #9ca3af;
}
.search-container.dark-mode .search-suggestions {
  background-color: #374151;
}
.search-container.dark-mode .search-suggestions .suggestion-text {
  color: #f0f0f0;
}
.search-container.dark-mode .suggestion-item {
  border-bottom: 1rpx solid #4b5563;
}
.search-container.dark-mode .search-error .error-text {
  color: #9ca3af;
}
.search-container.dark-mode .search-error .retry-button {
  background-color: #00d7cd;
  color: #1f2937;
}