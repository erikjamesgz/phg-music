.update-modal {
  width: 85%;
  max-width: 300px;
  background: #ffffff;
  border-radius: 12px;
  overflow: hidden;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  box-sizing: border-box;
}
.update-modal__header {
