
.music-comment-overlay.data-v-07a20cab {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 9999;
  display: flex;
  align-items: flex-end;
}
.music-comment.data-v-07a20cab {
  width: 100%;
  max-height: 80vh;
  background-color: #fff;
  border-radius: 16px 16px 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.comment-header.data-v-07a20cab {
  flex-shrink: 0;
  padding: 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1px solid #f0f0f0;
}
.comment-title.data-v-07a20cab {
  font-size: 16px;
  font-weight: 500;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.comment-header-btns.data-v-07a20cab {
  display: flex;
}
.comment-header-btn.data-v-07a20cab {
  margin-right: 12px;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}
.comment-header-btn.data-v-07a20cab:last-child {
  margin-right: 0;
}
.comment-main.data-v-07a20cab {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.tab-header.data-v-07a20cab {
  flex-shrink: 0;
  display: flex;
  padding: 12px 16px;
  border-bottom: 1px solid #f0f0f0;
}
.tab-item.data-v-07a20cab {
  display: flex;
  align-items: center;
  padding: 8px 0;
  margin-right: 24px;
  cursor: pointer;
}
.tab-item.data-v-07a20cab:last-child {
  margin-right: 0;
}
.tab-text.data-v-07a20cab {
  font-size: 14px;
  color: #666;
  transition: color 0.3s;
}
.tab-count.data-v-07a20cab {
  font-size: 12px;
  color: #666;
}
.tab-item.active .tab-text.data-v-07a20cab {
  color: #333;
  font-weight: 500;
}
.tab-item.active .tab-count.data-v-07a20cab {
  color: #333;
}
.tab-content.data-v-07a20cab {
  flex: 1;
  overflow: hidden;
  min-height: 0;
}
.comment-scroll.data-v-07a20cab {
  width: 100%;
  height: 100%;
}
.comment-error.data-v-07a20cab,
.comment-loading.data-v-07a20cab,
.comment-empty.data-v-07a20cab {
  padding: 40px 20px;
  text-align: center;
}
.error-text.data-v-07a20cab {
  font-size: 14px;
  color: #ff4d4f;
}
.loading-text.data-v-07a20cab {
  font-size: 14px;
  color: #999;
}
.empty-text.data-v-07a20cab {
  font-size: 14px;
  color: #999;
}
.load-more.data-v-07a20cab {
  padding: 16px;
  text-align: center;
}
.load-more-text.data-v-07a20cab {
  font-size: 12px;
  color: #999;
}
.comment-unavailable.data-v-07a20cab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
}
.unavailable-text.data-v-07a20cab {
  font-size: 14px;
  color: #999;
}
.dark-mode .music-comment.data-v-07a20cab {
  background-color: #1f2937;
}
.dark-mode .comment-header.data-v-07a20cab {
  background-color: #1f2937;
  border-bottom-color: rgba(255, 255, 255, 0.1);
}
.dark-mode .comment-title.data-v-07a20cab {
  color: #ffffff;
}
.dark-mode .tab-header.data-v-07a20cab {
  background-color: #1f2937;
  border-bottom-color: rgba(255, 255, 255, 0.1);
}
.dark-mode .tab-text.data-v-07a20cab {
  color: #9ca3af;
}
.dark-mode .tab-count.data-v-07a20cab {
  color: #9ca3af;
}
.dark-mode .tab-item.active .tab-text.data-v-07a20cab {
  color: #ffffff;
}
.dark-mode .tab-item.active .tab-count.data-v-07a20cab {
  color: #ffffff;
}
.dark-mode .empty-text.data-v-07a20cab,
.dark-mode .loading-text.data-v-07a20cab,
.dark-mode .load-more-text.data-v-07a20cab,
.dark-mode .unavailable-text.data-v-07a20cab {
  color: #737373;
}
.dark-mode .comment-scroll.data-v-07a20cab {
  background-color: #1f2937;
}

/* 平板模式：右侧滑出 */
.music-comment-overlay.tablet-overlay.data-v-07a20cab {
  align-items: stretch !important;
  justify-content: flex-end !important;
}
.music-comment.tablet-modal.data-v-07a20cab {
  width: 50% !important;
  max-width: 450px !important;
  height: 100vh !important;
  max-height: none !important;
  border-radius: 16px 0 0 16px !important;
  box-sizing: border-box !important;
}
.music-comment.tablet-modal .comment-main.data-v-07a20cab {
  flex: 1 !important;
  min-height: 0 !important;
  overflow: hidden !important;
}
.dark-mode .music-comment.tablet-modal .comment-header.data-v-07a20cab {
  background: #1f2937 !important;
  border-bottom-color: rgba(255, 255, 255, 0.1) !important;
}
