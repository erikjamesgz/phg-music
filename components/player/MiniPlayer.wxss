  display: flex;
  align-items: center;
  justify-content: center;
}
.mini-player__progress.data-v-2e8ed239 {
  height: 8rpx;
  background-color: rgba(0, 0, 0, 0.1);
  border-radius: 4rpx;
  position: relative;
  width: 100%;
  margin-top: 16rpx;
  z-index: 1001;
  /* 确保进度条在最上层 */
  overflow: visible;
  /* 确保在微信小程序中进度点可见 */
}
.mini-player__progress-bar.data-v-2e8ed239 {
  height: 100%;
  background: linear-gradient(90deg, #00d7cd 0%, #00afff 100%);
  border-radius: 4rpx;
}
.mini-player__progress-dot.data-v-2e8ed239 {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 24rpx;
  /* 增加宽度，改为水平长方形 */
  height: 12rpx;
  /* 减小高度 */
  background-color: #ffffff;
  border-radius: 6rpx;
  /* 增加圆角 */
  border: 2rpx solid #00d7cd;
  box-shadow: 0 0 8rpx rgba(0, 0, 0, 0.2);
  margin-left: -12rpx;
  /* 使长条居中于位置 */
  z-index: 1002;
  /* 确保在微信小程序中进度点在最上层 */
}

