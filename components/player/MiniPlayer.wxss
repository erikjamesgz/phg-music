.mini-player__artist-container.data-v-2e8ed239 {
  display: flex;
  align-items: center;
  margin-top: 4rpx;
}
.mini-player__artist-row.data-v-2e8ed239 {
  display: flex;
  align-items: center;
  margin-top: 4rpx;
}
.mini-player__sq-tag.data-v-2e8ed239 {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 16rpx;
  color: #ffffff;
  background-color: #00afff;
  padding: 0 6rpx;
