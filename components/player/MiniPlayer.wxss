  overflow: hidden;
}
.mini-player__info-row.data-v-2e8ed239 {
  display: flex;
  align-items: center;
  overflow: hidden;
  width: 100%;
}
.mini-player__marquee.data-v-2e8ed239 {
  flex: 1;
  overflow: hidden;
  position: relative;
  min-width: 0;
