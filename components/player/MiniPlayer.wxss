@keyframes marquee-2e8ed239 {
0% {
    transform: translateX(0);
}
100% {
    transform: translateX(-50%);
}
}
.mini-player-wrapper.data-v-2e8ed239 {
  position: fixed;
  left: 0;
  right: 0;
  bottom: var(--3759486d);
  /* 动态计算底部位置 */
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  z-index: 1001;
  /* 确保比底部导航栏的z-index(999)高，但要低于弹窗(1000) */
  width: 100%;
  pointer-events: auto;
  /* 确保可以点击 */
}
.mini-player-mp.data-v-2e8ed239 {
  position: static !important;
  /* 覆盖原有的relative定位 */
  width: 85% !important;
  margin: 0 auto !important;
}
.mini-player.data-v-2e8ed239 {
  pointer-events: auto;
  /* 确保可以点击 */
  width: 85%;
  height: 140rpx;
  /* 固定高度使其更协调，对应设计稿中的70px */
  z-index: 900;
  /* 确保比底部导航栏的z-index(999)高，但要低于弹窗(1000) */
  background-color: rgba(255, 255, 255, 0.95);
  background-color: rgba(255, 255, 255, 0.98);
  /* 微信小程序不支持backdrop-filter，使用更不透明的背景 */
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  border-radius: 32rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}
.mini-player__content.data-v-2e8ed239 {
  padding: 16rpx 24rpx;
  display: flex;
  flex-direction: column;
  height: 100%;
  box-sizing: border-box;
}
.mini-player__main.data-v-2e8ed239 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex: 1;
}
.mini-player__left.data-v-2e8ed239 {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
  margin-right: 20rpx;
}
.mini-player__cover-container.data-v-2e8ed239 {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
