}

/* 评论弹幕样式 - 绝对定位在MiniPlayer上方，不重叠 */
.mini-player-danmaku-area.data-v-2e8ed239 {
  position: absolute;
  left: 0;
  width: 100%;
  height: 28px;
  overflow: visible;
  pointer-events: none;
  z-index: 999;
  /* 相对于wrapper定位，在MiniPlayer上方 */
  bottom: 100%;
  margin-bottom: 8px;
}

/* iPhone 12 Pro Max 到 iPhone 15 Pro Max 等中等屏幕尺寸的适配 */
@media screen and (min-width: 390px) and (max-width: 430px) {
.mini-player-danmaku-area.data-v-2e8ed239 {
    margin-bottom: 12px;
}
}
.mini-player__danmaku-item.data-v-2e8ed239 {
  position: absolute;
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  background-color: rgba(0, 0, 0, 0.2);
  border-radius: 8px;
  white-space: nowrap;
  animation: mini-danmaku-move-2e8ed239 15s linear forwards;
  pointer-events: none;
  /* 确保单行显示，高度固定 */
  height: 24px;
  line-height: 20px;
  box-sizing: border-box;
}
.mini-player__danmaku-item.dark-mode.data-v-2e8ed239 {
  background-color: rgba(255, 255, 255, 0.08);
}
.mini-player__danmaku-item.paused.data-v-2e8ed239 {
  animation-play-state: paused;
}
@keyframes mini-danmaku-move-2e8ed239 {
0% {
    transform: translateX(100vw);
}
100% {
    transform: translateX(-100%);
}
}
