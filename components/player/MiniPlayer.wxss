  min-width: 0;
  height: 32rpx;
  display: flex;
  align-items: center;
}
.mini-player__status-content.data-v-2e8ed239 {
  display: flex;
  align-items: center;
  white-space: nowrap;
  flex-shrink: 0;
}
.mini-player__status-content.scroll.data-v-2e8ed239 {
