.modal-overlay.data-v-c94912fa {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 9999;
}
.about-modal.data-v-c94912fa {
  width: 85%;
  max-width: 300px;
  background: #ffffff;
  border-radius: 12px;
  overflow: hidden;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  box-sizing: border-box;
}
.about-modal__header.data-v-c94912fa {
  padding: 24px 16px 16px;
  text-align: center;
  background: linear-gradient(180deg, rgba(0, 215, 205, 0.08) 0%, rgba(255, 255, 255, 0) 100%);
  box-sizing: border-box;
}
.about-modal__body.data-v-c94912fa {
  max-height: 40vh;
  padding: 0 16px;
  box-sizing: border-box;
  width: 100%;
}
.about-modal__footer.data-v-c94912fa {
  padding: 12px 16px 16px;
  box-sizing: border-box;
}
.about-modal__btn.data-v-c94912fa {
  width: 100%;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 500;
  box-sizing: border-box;
  background: linear-gradient(135deg, #00d7cd 0%, #00afff 100%);
  color: #ffffff;
  box-shadow: 0 2px 8px rgba(0, 215, 205, 0.3);
}
.about-modal__btn.data-v-c94912fa:active {
  transform: scale(0.98);
}
.about-modal__btn--disabled.data-v-c94912fa {
  opacity: 0.5;
  pointer-events: none;
}
.about-modal.dark-mode.data-v-c94912fa {
  background: #1f2937;
}
.about-modal.dark-mode .about-modal__header.data-v-c94912fa {
  background: linear-gradient(180deg, rgba(0, 215, 205, 0.15) 0%, rgba(31, 41, 55, 0) 100%);
}
.about-logo.data-v-c94912fa {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8px;
}
.about-logo__icon.data-v-c94912fa {
  width: 40px;
  height: 40px;
  margin-right: 10px;
  background: linear-gradient(135deg, #00d7cd 0%, #00afff 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 8px rgba(0, 175, 255, 0.3);
